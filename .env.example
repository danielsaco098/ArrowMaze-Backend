# HTTP port the API listens on
PORT=3000

# Secret used to sign JWT access tokens (use a long random value in production)
JWT_SECRET=change-me-in-production

# Access-token lifetime (any value accepted by `ms`, e.g. 15m, 1h, 1d)
JWT_EXPIRES_IN=1d

# Default admin account seeded on startup (used for admin-only endpoints)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345

# --- Database (PostgreSQL) ---
# Leave DATABASE_URL empty to fall back to in-memory persistence (no DB needed).
# DATABASE_SSL: false for local Postgres, true for cloud Postgres (Neon/Supabase).
# DATABASE_SYNCHRONIZE: auto-create/update tables from the entities on boot.

# Local Postgres (development)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arrowmaze
DATABASE_SSL=false
DATABASE_SYNCHRONIZE=true

# Remote Postgres (e.g. Neon / Supabase) — swap DATABASE_URL for your cloud one:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME
# DATABASE_SSL=true
